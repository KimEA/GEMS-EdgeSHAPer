# ── 실험 결과 (로컬에서만 사용) ───────────────────────────────────────────────
results/
logs/

# ── 데이터셋 / 사용자 학습 체크포인트 (Google Drive에 보관) ──────────────────
# GEMS/model/ 사전학습 가중치(.pt)는 트래킹함 — 아래 규칙에서 제외
*.pt
!GEMS/model/*.pt

# ── Python 캐시 ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── 가상환경 ──────────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── 에디터 ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 기타 임시 파일 ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
